## Tracing app environment variables

# Base URL for the agents API. Use /api for local dev (mocked by Vite).
VITE_API_BASE_URL=/api

# Optional: override API proxy target for /socket.io
# VITE_PROXY_TARGET=http://platform-server:3010

# Optional: override LLM gateway for /apiv2 proxy
# VITE_LLM_GATEWAY_URL=http://llm-gateway:8080
